# Copy to .env and fill in. NEVER put real secrets in this file.
# frontend/.env is a symlink to the repo-root .env, so backend + frontend share one file.
# The system runs end-to-end WITHOUT any AI key (deterministic fallbacks for
# explain / rank / classify / report); a key only upgrades the advisory layer.

# --- Database (system of record; shared by the FastAPI backend + Auth.js) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require

# --- AI / advisory layer ----------------------------------------------------
# Provider selection: auto | ollama | anthropic | openai
#   auto      -> hosted if a key is present, else local Ollama  (default)
ADVISORY_PROVIDER=auto

# Local-first (Ollama). Use ONE model for judge + prose to avoid unloading /
# reloading multi-GB models between calls (which causes cold-start stalls).
OLLAMA_HOST=http://localhost:11434
OLLAMA_JUDGE_MODEL=qwen3-coder:30b
OLLAMA_PROSE_MODEL=qwen3-coder:30b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=600

# Hosted providers (optional; used when selected, or under "auto" if a key is set).
ANTHROPIC_API_KEY=sk-ant-...
ADVISORY_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Backend (FastAPI) ------------------------------------------------------
# Origin allowed to call the API directly (CORS).
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (Next.js + Auth.js) -------------------------------------------
AUTH_SECRET=run: openssl rand -base64 32
AUTH_TRUST_HOST=true
# Canonical app origin for magic-link + invite URLs. Leave APP_URL blank to
# auto-derive from the request host (recommended for deploys behind a proxy).
APP_URL=http://localhost:3000
# AUTH_URL=https://your-app.example.com
# Where the Next dev server proxies /api/* (the FastAPI backend).
BACKEND_URL=http://127.0.0.1:8000

# --- Email (Resend; optional) -----------------------------------------------
# Without these, password login still works and magic / reset links print to
# the server console instead of being emailed.
RESEND_API_KEY=re_...
EMAIL_FROM=ZeroTrust Advisor <noreply@yourdomain.com>

# --- Admin bootstrap --------------------------------------------------------
# First admin created by: node frontend/scripts/create-admin.mjs
ADMIN_EMAIL=you@example.com
